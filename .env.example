# ============================================================
# VedaAI Assessment Creator — Environment Variables
# Copy this file to .env and fill in the values before running.
# Never commit your actual .env file to version control.
# ============================================================

# MongoDB connection string (including database name)
# Example: mongodb://localhost:27017/vedaai
# In Docker Compose this is typically: mongodb://mongodb:27017/vedaai
MONGO_URI=mongodb://localhost:27017/vedaai

# Redis connection URL used by BullMQ (job queue) and paper caching
# Example: redis://localhost:6379
# In Docker Compose this is typically: redis://redis:6379
REDIS_URL=redis://localhost:6379

# Secret key used to sign and verify JSON Web Tokens (JWTs)
# Must be a long, random, high-entropy string — treat it like a password
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Google OAuth 2.0 Client ID obtained from the Google Cloud Console
# Required for "Sign in with Google" functionality
# See: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google OAuth 2.0 Client Secret obtained from the Google Cloud Console
# Keep this value confidential — never expose it in client-side code
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The publicly accessible URL of the Next.js frontend application
# Used by the API for CORS origin validation and OAuth redirect configuration
# Example (local dev): http://localhost:3000
# Example (production): https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Public base URL of the Express API (required for Google OAuth callback URL)
# Render sets RENDER_EXTERNAL_URL automatically — you can omit API_URL on Render
# Example (local dev): http://localhost:5000
# Example (production): https://vedaai-api.onrender.com
API_URL=http://localhost:5000

# ── Frontend-only (set in Vercel project settings) ──────────────────────────
# NEXT_PUBLIC_API_URL=https://vedaai-api.onrender.com
# NEXT_PUBLIC_SOCKET_URL=https://vedaai-api.onrender.com

# Google Gemini API key used by the BullMQ worker to call the Gemini 1.5 Flash model
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# TCP port on which the Express API server listens
# Defaults to 5000 if not set; must match the Docker Compose port mapping for the api service
PORT=5000
